{
    "version": "1.0",
    "id": "TP6-inner",
    "name": "Toy Problem 6 Inner",
    "description": "Inner blueprint for Toy Problem 6 to print element guids",
    "tasks": [
        {
            "id": "start",
            "type": "system.start",
            "outputs": [
                {
                    "name": "process_start_time",
                    "type": "timestamp"
                }
            ]
        },
        {
            "id": "A1",
            "type": "user_interaction.user_output",
            "description": "Print element ID",
            "inputs": [
                {
                    "name": "element",
                    "type": "dict"
                }
            ],
            "outputs": [
                {
                    "name": "result",
                    "type": "str"
                }
            ],
            "depends_on": [
                {
                    "id": "start"
                }
            ]
        },
        {
            "id": "end",
            "type": "system.end",
            "outputs": [
                {
                    "name": "process_end_time",
                    "type": "timestamp"
                }
            ],
            "depends_on": [
                {
                    "id": "A1"
                }
            ]
        }
    ]
}