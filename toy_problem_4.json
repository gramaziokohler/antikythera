{
  "version": "1.0",
  "id": "TP4",
  "name": "Toy Problem 4",
  "description": "Inner blueprints using composite",
  "tasks": [
    {
      "id": "start",
      "type": "system.start",
      "outputs": {
        "process_start_time": "timestamp"
      }
    },
    {
      "id": "X1",
      "type": "user_interaction.user_input",
      "description": "Wait for user input",
      "outputs": {
        "something": "str"
      },
      "depends_on": [
        {"id": "start"}
      ]
    },

    {
      "id": "X2",
      "type": "system.composite",
      "description": "Call inner blueprint",
      "inputs": {
          "something": "str"
      },
      "outputs": {
          "result1": "str"
      },
      "blueprint": {
        "static": "toy_problem_4_inner.json"
      },

      "depends_on": [
        {"id": "X1", "type": "FS"}
      ]
    },

    {
      "id": "X3",
      "type": "user_interaction.user_output",
      "description": "Print result",
      "inputs": {
        "result1": "str"
      },
      "depends_on": [
        {"id": "X2"}
      ]
    },

    {
      "id": "end",
      "type": "system.end",
      "outputs": {
        "process_end_time": "timestamp"
      },
      "depends_on": [
        {"id": "X3"}
      ]
    }
  ]
}
