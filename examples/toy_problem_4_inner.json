{
  "version": "1.0",
  "id": "TP4_PnP",
  "name": "Toy Problem 4 - Inner blueprint",
  "description": "Inner blueprints using composite",
  "tasks": [
    {
      "id": "start",
      "type": "system.start",
      "outputs": [
        {
          "name": "process_start_time",
          "type": "timestamp"
        }
      ]
    },
    {
      "id": "A1",
      "type": "user_interaction.user_input",
      "description": "Wait for user input",
      "outputs": [
        {
          "name": "result1",
          "type": "str"
        }
      ],
      "depends_on": [
        {
          "id": "start"
        }
      ]
    },
    {
      "id": "A2",
      "type": "system.sleep",
      "description": "Sleep for 5 seconds",
      "params": [
        {
          "name": "duration",
          "value": 5
        }
      ],
      "depends_on": [
        {
          "id": "start"
        }
      ]
    },
    {
      "id": "B1",
      "type": "user_interaction.user_output",
      "description": "Print result",
      "inputs": [
        {
          "name": "bananas",
          "type": "str",
          "get_from": "result1"
        }
      ],
      "depends_on": [
        {
          "id": "A1",
          "type": "FS"
        },
        {
          "id": "A2",
          "type": "FS"
        }
      ]
    },
    {
      "id": "end",
      "type": "system.end",
      "outputs": [
        {
          "name": "process_end_time",
          "type": "timestamp"
        }
      ],
      "depends_on": [
        {
          "id": "B1"
        }
      ]
    }
  ]
}