{
  "version": "1.0",
  "id": "toy-problem-0",
  "name": "Toy Problem 0",
  "description": "Simplest possible blueprint",
  "tasks": [
    {
      "id": "start",
      "type": "system.start",
      "outputs": [
        {
          "name": "process_start_time",
          "type": "timestamp"
        }
      ]
    },
    {
      "id": "A1",
      "type": "system.sleep",
      "description": "Sleep for 5 seconds",
      "params": [
        {
          "name": "duration",
          "value": 5
        }
      ],
      "depends_on": [
        {
          "id": "start"
        }
      ]
    },
    {
      "id": "A2",
      "type": "user_interaction.user_output",
      "description": "Print result",
      "inputs": [
        {
          "name": "process_start_time",
          "type": "timestamp"
        }
      ],
      "depends_on": [
        {
          "id": "A1"
        }
      ]
    },
    {
      "id": "end",
      "type": "system.end",
      "outputs": [
        {
          "name": "process_end_time",
          "type": "timestamp"
        }
      ],
      "depends_on": [
        {
          "id": "A2"
        }
      ]
    }
  ]
}