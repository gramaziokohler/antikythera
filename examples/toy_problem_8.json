{
    "version": "1.0",
    "id": "toy-problem-8",
    "name": "Toy Problem 8",
    "description": "Conditional execution based on previous result",
    "tasks": [
        {
            "id": "start",
            "type": "system.start",
            "outputs": [
                {
                    "name": "process_start_time",
                    "type": "timestamp"
                }
            ]
        },
        {
            "id": "A1-ask-user",
            "type": "user_prompt.confirm",
            "params": [
                {
                    "name": "message",
                    "value": "Do you want to proceed?"
                },
                {
                    "name": "options",
                    "value": [
                        "Yes",
                        "No"
                    ]
                }
            ],
            "outputs": [
                {
                    "name": "result",
                    "type": "str"
                }
            ],
            "depends_on": [
                {
                    "id": "start"
                }
            ]
        },
        {
            "id": "A1-extra",
            "type": "user_prompt.confirm",
            "description": "Conditional prompt that only runs if user said Yes",
            "condition": "decision == 'Yes'",
            "params": [
                {
                    "name": "message",
                    "value": "You chose Yes. Are you absolutely sure?"
                },
                {
                    "name": "options",
                    "value": [
                        "I am sure",
                        "Actually no"
                    ]
                }
            ],
            "inputs": [
                {
                    "name": "decision",
                    "type": "str",
                    "get_from": "result"
                }
            ],
            "outputs": [
                {
                    "name": "result",
                    "type": "str",
                    "set_to": "result_extra"
                }
            ],
            "depends_on": [
                {
                    "id": "A1-ask-user"
                }
            ]
        },
        {
            "id": "A2",
            "type": "system.sleep",
            "description": "Sleep for 5 seconds",
            "params": [
                {
                    "name": "duration",
                    "value": 5
                }
            ],
            "depends_on": [
                {
                    "id": "start"
                }
            ]
        },
        {
            "id": "B1",
            "type": "user_interaction.user_output",
            "description": "Print result",
            "inputs": [
                {
                    "name": "result",
                    "type": "str"
                },
                {
                    "name": "extra_info",
                    "type": "str",
                    "get_from": "result_extra",
                    "value": "N/A"
                },
                {
                    "name": "frame_world_xy",
                    "value": {
                        "dtype": "compas.geometry/Frame",
                        "data": {
                            "point": [
                                0.0,
                                0.0,
                                0.0
                            ],
                            "xaxis": [
                                1.0,
                                0.0,
                                0.0
                            ],
                            "yaxis": [
                                0.0,
                                1.0,
                                0.0
                            ]
                        },
                        "guid": "55982853-464f-49f0-a85a-f5a4a8b11de7"
                    }
                }
            ],
            "depends_on": [
                {
                    "id": "A1-extra",
                    "type": "FS"
                },
                {
                    "id": "A2",
                    "type": "FS"
                }
            ]
        },
        {
            "id": "end",
            "type": "system.end",
            "outputs": [
                {
                    "name": "process_end_time",
                    "type": "timestamp"
                }
            ],
            "depends_on": [
                {
                    "id": "B1"
                }
            ]
        }
    ]
}