{
  "version": "1.0",
  "id": "toy-problem-2",
  "name": "Toy Problem 2",
  "description": "A sample fabrication process definition",
  "tasks": [
    {
      "id": "start",
      "type": "system.start",
      "outputs": [
        {
          "name": "process_start_time",
          "type": "timestamp"
        }
      ]
    },
    {
      "id": "A1",
      "type": "fall_demonstrator.select_frames",
      "description": "Select frames for planning process",
      "outputs": [
        {
          "name": "frames",
          "type": "list[compas.geometry.Frame]"
        }
      ],
      "depends_on": [
        {
          "id": "start"
        }
      ]
    },
    {
      "id": "A2",
      "type": "fall_demonstrator.plan_motion",
      "description": "Plan motion for frames",
      "inputs": [
        {
          "name": "frames",
          "type": "list[compas.geometry.Frame]"
        }
      ],
      "outputs": [
        {
          "name": "trajectory",
          "type": "compas_fab.robots.Trajectory"
        }
      ],
      "depends_on": [
        {
          "id": "A1"
        }
      ]
    },
    {
      "id": "end",
      "type": "system.end",
      "outputs": [
        {
          "name": "process_end_time",
          "type": "timestamp"
        }
      ],
      "depends_on": [
        {
          "id": "A2"
        }
      ]
    }
  ]
}