{
  "version": "1.0",
  "id": "toy-problem-7",
  "name": "Toy Problem 7",
  "description": "A sample fabrication process definition with user prompt",
  "tasks": [
    {
      "id": "start",
      "type": "system.start",
      "outputs": {
        "process_start_time": "timestamp"
      }
    },
    {
      "id": "A1-ask-user",
      "type": "user_prompt.confirm",
      "params": {
        "message": "Do you want to proceed?",
        "options": [
          "Yes",
          "No"
        ]
      },
      "outputs": {
        "result": "str"
      },
      "depends_on": [
        {
          "id": "start"
        }
      ]
    },
    {
      "id": "A2",
      "type": "system.sleep",
      "description": "Sleep for 5 seconds",
      "duration": 5,
      "depends_on": [
        {
          "id": "start"
        }
      ]
    },
    {
      "id": "B1",
      "type": "user_interaction.user_output",
      "description": "Print result",
      "inputs": {
        "result": "str",
        "frame_world_xy": {
          "dtype": "compas.geometry/Frame",
          "data": {
            "point": [
              0.0,
              0.0,
              0.0
            ],
            "xaxis": [
              1.0,
              0.0,
              0.0
            ],
            "yaxis": [
              0.0,
              1.0,
              0.0
            ]
          },
          "guid": "55982853-464f-49f0-a85a-f5a4a8b11de7"
        }
      },
      "depends_on": [
        {
          "id": "A1-ask-user",
          "type": "FS"
        },
        {
          "id": "A2",
          "type": "FS"
        }
      ]
    },
    {
      "id": "end",
      "type": "system.end",
      "outputs": {
        "process_end_time": "timestamp"
      },
      "depends_on": [
        {
          "id": "B1"
        }
      ]
    }
  ]
}